page {
  min-height: 100%;
  background: #ffffff;
  color: #17212b;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.with-tabbar {
  padding-bottom: 48rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.06);
  margin-bottom: 24rpx;
  box-sizing: border-box;
  border: 1rpx solid #edf0f3;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #17212b;
  line-height: 1.25;
}

.subtitle {
  margin-top: 10rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.65;
}

.primary-btn,
.outline-btn {
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.primary-btn::after,
.outline-btn::after {
  border: none;
}

.primary-btn {
  background: #168d75;
  color: #fff;
  box-shadow: 0 10rpx 22rpx rgba(22, 141, 117, 0.18);
}

.outline-btn {
  border: 1rpx solid #d5dce3;
  color: #26323f;
  background: #ffffff;
}
