<view class="tabbar-shell">
  <view class="tabbar">
    <view
      wx:for="{{ tabs }}"
      wx:key="key"
      class="tab-item {{ current === item.key ? 'is-active' : '' }}"
      data-key="{{ item.key }}"
      data-path="{{ item.path }}"
      bindtap="handleSwitch"
    >
      <view class="tab-icon">{{ item.icon }}</view>
      <view class="tab-label">{{ item.label }}</view>
    </view>
  </view>
</view>