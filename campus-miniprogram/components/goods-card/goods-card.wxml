<view class="goods-card">
  <view class="cover-wrap">
    <image wx:if="{{ item.coverImage }}" class="cover-image" src="{{ item.coverImage }}" mode="aspectFill" data-src="{{ item.coverImage }}" binderror="handleImageError" />
    <view wx:else class="cover-placeholder">暂无图片</view>
  </view>

  <view class="goods-info">
    <view class="goods-title">{{ item.title }}</view>
    <view class="goods-desc">{{ item.description || "卖家暂未填写描述" }}</view>

    <view class="goods-bottom">
      <view class="goods-price">￥{{ item.price }}</view>
      <view class="status-chip">{{ item.statusText || "在售" }}</view>
    </view>

    <view class="goods-meta-row">
      <view wx:if="{{ item.distanceText }}" class="distance-tag">距你 {{ item.distanceText }}</view>
      <view wx:if="{{ item.trade_address }}" class="goods-address">{{ item.trade_address }}</view>
    </view>
  </view>
</view>
