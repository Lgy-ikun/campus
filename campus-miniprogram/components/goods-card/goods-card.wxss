.goods-card {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #edf0f3;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.06);
  box-sizing: border-box;
}

.cover-wrap {
  flex-shrink: 0;
  width: 188rpx;
  height: 188rpx;
  border-radius: 14rpx;
  overflow: hidden;
  background: #f3f6f8;
}

.cover-image,
.cover-placeholder {
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #98a2b3;
  font-size: 23rpx;
}

.goods-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.goods-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #17212b;
  line-height: 1.35;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.goods-desc {
  margin-top: 10rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.goods-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-top: auto;
}

.goods-price {
  flex: 1;
  min-width: 0;
  color: #d45712;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.2;
}

.status-chip {
  flex-shrink: 0;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #ecfdf3;
  color: #168d75;
  font-size: 21rpx;
  line-height: 1.3;
}

.goods-meta-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 12rpx;
  min-width: 0;
}

.distance-tag {
  flex-shrink: 0;
  padding: 5rpx 10rpx;
  border-radius: 8rpx;
  background: #eff8ff;
  color: #175cd3;
  font-size: 21rpx;
  line-height: 1.3;
}

.goods-address {
  flex: 1;
  min-width: 0;
  color: #667085;
  font-size: 22rpx;
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
