.helper-text {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #8a919f;
}

.preview-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 20rpx;
}

.preview-item {
  position: relative;
}

.preview-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #f5f7fa;
  border: 1rpx solid #edf0f3;
  box-sizing: border-box;
}

.remove-btn {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.68);
  color: #fff;
  font-size: 28rpx;
  line-height: 40rpx;
  text-align: center;
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.12);
}
