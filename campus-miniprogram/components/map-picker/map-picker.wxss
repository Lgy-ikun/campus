.map-card {
  overflow: hidden;
}

.section-title {
  font-size: 28rpx;
  color: #17212b;
}

.location-map {
  width: 100%;
  height: 320rpx;
  margin-top: 18rpx;
  border-radius: 14rpx;
  overflow: hidden;
  background: #eef3f7;
  border: 1rpx solid #e6ebf0;
  box-sizing: border-box;
}

.search-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
  margin-top: 16rpx;
}

.search-field {
  flex: 1;
  margin-top: 0;
}

.search-btn {
  flex-shrink: 0;
  min-width: 152rpx;
}

.location-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 16rpx;
}

.location-btn {
  width: 100%;
  margin: 0;
}

.field {
  height: 82rpx;
  margin-top: 16rpx;
  padding: 0 24rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  border: 1rpx solid #e6ebf0;
  box-sizing: border-box;
  color: #17212b;
  font-size: 26rpx;
}

.poi-list {
  margin-top: 16rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f8fafc;
  border: 1rpx solid #edf0f3;
}

.poi-item {
  padding: 18rpx 20rpx;
  border-bottom: 1rpx solid #edf0f3;
}

.poi-item:last-child {
  border-bottom: none;
}

.poi-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #17212b;
}

.poi-address {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #667085;
  line-height: 1.6;
}

.selected-tip {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  border: 1rpx solid #edf0f3;
  font-size: 24rpx;
  color: #485467;
  line-height: 1.6;
}

