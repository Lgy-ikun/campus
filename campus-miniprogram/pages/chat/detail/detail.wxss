.chat-detail-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 0;
  background: #ededed;
  box-sizing: border-box;
  overflow: hidden;
}

.chat-head {
  flex-shrink: 0;
  margin: 20rpx 20rpx 12rpx;
  padding: 20rpx 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  border-radius: 12rpx;
  box-shadow: none;
  border-color: #e2e2e2;
}

.chat-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
}

.chat-meta {
  margin-top: 6rpx;
  color: #8a8f98;
  font-size: 22rpx;
  line-height: 1.4;
}

.pin-btn {
  flex-shrink: 0;
  width: 136rpx;
  height: 56rpx;
  line-height: 56rpx;
  margin: 0;
  padding: 0;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.chat-scroll {
  flex: 1;
  min-height: 0;
  padding: 18rpx 20rpx 24rpx;
  box-sizing: border-box;
}

.message-row {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.message-row.self {
  align-items: flex-end;
}

.message-bubble {
  max-width: 74%;
  padding: 15rpx 20rpx;
  border-radius: 10rpx;
  background: #ffffff;
  color: #111827;
  font-size: 28rpx;
  line-height: 1.55;
  word-break: break-word;
  box-sizing: border-box;
}

.message-row.self .message-bubble {
  background: #95ec69;
}

.message-bubble.image-bubble {
  width: auto;
  max-width: 260rpx;
  padding: 0;
  overflow: hidden;
  background: transparent;
  border-radius: 12rpx;
}

.message-image {
  display: block;
  width: 260rpx;
  height: 190rpx;
  border-radius: 12rpx;
  background: #d9d9d9;
}

.message-time {
  margin-top: 8rpx;
  color: #9ca3af;
  font-size: 20rpx;
  line-height: 1.2;
}

.composer {
  flex-shrink: 0;
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  padding: 12rpx 18rpx calc(12rpx + env(safe-area-inset-bottom));
  background: #f6f6f6;
  border-top: 1rpx solid #dddddd;
  box-sizing: border-box;
}

.composer-action {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  min-width: 0;
  height: 64rpx;
  line-height: 1;
  box-shadow: none;
  border: 0;
  outline: none;
  box-sizing: border-box;
  font-weight: 500;
  overflow: visible;
}

.composer-action--hover {
  background: #e8e8e8;
}

.media-btn {
  width: 64rpx;
  border-radius: 50%;
  background: #ffffff;
  color: #333333;
  border: 1rpx solid #d2d2d2;
}

.media-btn__plus {
  position: relative;
  top: -1rpx;
  font-size: 42rpx;
  line-height: 1;
  font-weight: 300;
}

.media-btn__loading {
  color: #666666;
  font-size: 22rpx;
  line-height: 1;
}

.send-btn {
  width: 86rpx;
  height: 64rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  background: #07c160;
  color: #ffffff;
  letter-spacing: 0;
}

.send-btn--hover {
  background: #06ad56;
}

.composer-input {
  flex: 1;
  min-width: 0;
  min-height: 64rpx;
  max-height: 176rpx;
  padding: 15rpx 20rpx;
  border-radius: 10rpx;
  background: #ffffff;
  color: #111827;
  font-size: 29rpx;
  line-height: 34rpx;
  box-sizing: border-box;
  overflow-y: auto;
}

.composer-placeholder {
  color: #a0a4aa;
}
