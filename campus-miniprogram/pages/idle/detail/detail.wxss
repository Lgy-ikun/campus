.detail-page {
  background: #ffffff;
  padding-bottom: 180rpx;
}

.cover-card {
  margin: 0 -24rpx 20rpx;
  background: #f3f6f8;
}

.cover-image {
  width: 100%;
  height: 520rpx;
  display: block;
}

.detail-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.price {
  flex: 1;
  min-width: 0;
  font-size: 52rpx;
  font-weight: 800;
  color: #d45712;
  line-height: 1.1;
}

.status-chip {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #ecfdf3;
  color: #168d75;
  font-size: 22rpx;
  line-height: 1.4;
}

.goods-title {
  margin-top: 16rpx;
  line-height: 1.35;
}

.seller-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 16rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 1.5;
}

.detail-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #17212b;
  margin-bottom: 12rpx;
}

.distance-text {
  margin-top: 12rpx;
  color: #175cd3;
  font-size: 24rpx;
  line-height: 1.6;
}

.location-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.refresh-btn,
.nav-btn {
  width: 100%;
  margin-top: 0;
}

.detail-map {
  width: 100%;
  height: 300rpx;
  margin-top: 18rpx;
  border-radius: 14rpx;
  overflow: hidden;
  background: #eef3f7;
  border: 1rpx solid #e6ebf0;
  box-sizing: border-box;
}

.reason-box {
  padding: 18rpx 20rpx;
  border-radius: 12rpx;
  background: #fff7ed;
  color: #b54708;
  font-size: 24rpx;
  line-height: 1.6;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.detail-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background: #f5f7fa;
  border: 1rpx solid #edf0f3;
  box-sizing: border-box;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  gap: 16rpx;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid #edf0f3;
  box-shadow: 0 -10rpx 30rpx rgba(15, 23, 42, 0.08);
  box-sizing: border-box;
}

.bar-btn {
  width: auto;
  min-width: 160rpx;
  margin-top: 0;
}

.main-action {
  flex: 1;
}
