.my-goods-page {
  background: #ffffff;
  padding-bottom: 56rpx;
}

.filter-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.filter-chip {
  padding: 10rpx 18rpx;
  border-radius: 10rpx;
  background: #f8fafc;
  border: 1rpx solid #e6ebf0;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.4;
}

.filter-chip.active {
  background: #168d75;
  border-color: #168d75;
  color: #fff;
}

.publish-btn {
  margin-top: 20rpx;
}

.record-card {
  margin-bottom: 24rpx;
  padding: 22rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #edf0f3;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.06);
  box-sizing: border-box;
}

.record-main {
  display: flex;
  gap: 20rpx;
}

.record-cover {
  position: relative;
  flex-shrink: 0;
  width: 176rpx;
  height: 176rpx;
  border-radius: 14rpx;
  overflow: hidden;
  background: #f3f6f8;
}

.record-image,
.record-placeholder {
  width: 100%;
  height: 100%;
}

.record-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #98a2b3;
  font-size: 22rpx;
}

.record-status {
  position: absolute;
  left: 10rpx;
  bottom: 10rpx;
  max-width: 132rpx;
  padding: 5rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(23, 33, 43, 0.78);
  color: #ffffff;
  font-size: 20rpx;
  line-height: 1.3;
}

.record-info {
  flex: 1;
  min-width: 0;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
}

.record-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 700;
  color: #17212b;
  line-height: 1.35;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.record-price {
  flex-shrink: 0;
  color: #d45712;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.2;
}

.record-desc {
  margin-top: 12rpx;
  color: #475467;
  font-size: 24rpx;
  line-height: 1.55;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.record-meta {
  margin-top: 8rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 1.5;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.record-reason {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 12rpx;
  background: #fff7ed;
  color: #b54708;
  font-size: 23rpx;
  line-height: 1.6;
}

.record-footer {
  display: flex;
  justify-content: flex-end;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #edf0f3;
}

.footer-btn {
  margin-top: 0;
  min-width: 220rpx;
}

.empty-card {
  text-align: center;
  padding: 48rpx 32rpx;
}
