.page-wrapper {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #f4fffb 0%, #eef9ff 42%, #f7fbf6 100%);
  padding-bottom: 44rpx;
  box-sizing: border-box;
}

.swiper-list {
  width: 100%;
  height: 360rpx;
  flex-shrink: 0;
  background: #dff8f2;
}

.hero-slide {
  height: 100%;
  padding: 42rpx 42rpx 82rpx;
  color: #fff;
  box-sizing: border-box;
}
.hero-copy { position: relative; z-index: 1; }
.hero-mint { background: linear-gradient(135deg, #5ed6bc 0%, #21b9a7 50%, #1594b4 100%); }
.hero-sky { background: linear-gradient(135deg, #7bc8ff 0%, #42a8e6 52%, #3288d3 100%); }
.hero-sunrise { background: linear-gradient(135deg, #8ddfca 0%, #52c8b5 46%, #ffc86a 100%); }
.hero-eyebrow { padding: 10rpx 20rpx; border-radius: 999rpx; background: rgba(255,255,255,0.22); font-size: 22rpx; font-weight: 700; }
.hero-title { margin-top: 20rpx; font-size: 38rpx; font-weight: 700; line-height: 1.35; }
.hero-desc { margin-top: 12rpx; font-size: 24rpx; color: rgba(255,255,255,0.9); }
.hero-tags { display: flex; gap: 12rpx; margin-top: 16rpx; }
.hero-tag { padding: 8rpx 16rpx; border-radius: 999rpx; background: rgba(255,255,255,0.18); font-size: 22rpx; }

.home-body {
  flex: 1;
  padding: 0 24rpx;
  margin-top: -44rpx;
  position: relative;
  z-index: 2;
}

/* 登录卡片 */
.login-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 26rpx;
  border-radius: 28rpx;
  background: rgba(255,255,255,0.94);
  box-shadow: 0 18rpx 44rpx rgba(32,156,140,0.12);
  border: 1rpx solid rgba(52,211,153,0.18);
}
.login-card.is-logged { border-color: rgba(56,189,248,0.18); }
.login-kicker { font-size: 22rpx; color: #0f9f91; font-weight: 700; }
.login-title { margin-top: 10rpx; font-size: 26rpx; font-weight: 700; color: #173b3f; }
.login-chip { padding: 0 20rpx; height: 54rpx; line-height: 54rpx; border-radius: 999rpx; background: #12b8a6; color: #fff; font-size: 23rpx; font-weight: 700; }

/* 通知条 */
.notice-strip {
  margin-top: 14rpx;
  padding: 0 22rpx;
  height: 68rpx;
  border-radius: 22rpx;
  background: #fffdf6;
  border: 1rpx solid rgba(251,191,36,0.24);
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.notice-mark { width: 16rpx; height: 16rpx; border-radius: 50%; background: #f7b733; }
.notice-text { flex: 1; font-size: 24rpx; color: #64706f; }
.notice-action { font-size: 23rpx; color: #0f9f91; font-weight: 700; }

/* 🔥 核心修复：功能区样式 + 文字全显示 */
.home-actions {
  margin-top: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.action-row {
  display: flex;
  gap: 20rpx;
}
.top-row {
  height: 320rpx;
}
.bottom-row {
  height: 320rpx;
}

/* 按钮容器 */
.action-item {
  flex: 1;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 12rpx 30rpx rgba(22,72,77,0.07);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  position: relative;
}
.big-item { flex: 1; }
.small-item { width: 100%; }

/* 图标 */
.action-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: #e8fbf5;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  margin-bottom: 20rpx;
}
.action-icon image {
  width: 50rpx;
  height: 50rpx;
}
.action-badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #eef9ff;
  color: #2780b8;
  font-size: 20rpx;
  font-weight: 700;
}

/* 🔥 文字强制可见 */
.action-texts {
  text-align: center;
  width: 100%;
}
.action-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #173b3f !important;
  margin-bottom: 8rpx;
}
.action-desc {
  font-size: 24rpx;
  color: #71817f !important;
}

/* 按压效果 */
.pressed {
  transform: scale(0.96);
  opacity: 0.8;
}
.pressed-soft {
  transform: scale(0.99);
  opacity: 0.82;
}