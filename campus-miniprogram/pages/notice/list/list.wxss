.notice-page {
  background: linear-gradient(180deg, #f8eee5 0%, #f7f1eb 220rpx, #f7f1eb 100%);
}

.hero-card {
  background: linear-gradient(135deg, #ffffff 0%, #f1faee 100%);
}

.hero-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 24rpx;
}

.hero-badge {
  display: inline-flex;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(138, 90, 68, 0.1);
  color: #8a5a44;
  font-size: 24rpx;
  font-weight: 700;
}

.hero-btn {
  margin: 0;
  min-width: 180rpx;
}

.filter-row {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.filter-chip {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: #eef2ec;
  color: #5b6473;
  font-size: 24rpx;
  font-weight: 600;
}

.filter-chip.active {
  background: #8a5a44;
  color: #fff;
}

.notice-card {
  transition: all 0.2s ease;
}

.notice-card.is-unread {
  border: 2rpx solid rgba(138, 90, 68, 0.12);
}

.notice-card.is-read {
  opacity: 0.9;
}

.notice-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.notice-head-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.notice-chip {
  display: inline-flex;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #8a5a44;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
}

.notice-chip.muted {
  background: #e5e7eb;
  color: #6b7280;
}

.notice-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #dc2626;
}

.notice-time {
  color: #6b7280;
  font-size: 22rpx;
}

.notice-title {
  margin-top: 18rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #3f2d26;
}

.notice-content {
  margin-top: 14rpx;
  color: #475569;
  font-size: 25rpx;
  line-height: 1.7;
}

.notice-action {
  margin-top: 18rpx;
  color: #8a5a44;
  font-size: 24rpx;
  font-weight: 600;
}

.empty-card {
  text-align: center;
}
