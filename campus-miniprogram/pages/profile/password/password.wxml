<view class="page password-page">
  <view class="card hero-card">
    <view class="title">修改密码</view>
    <view class="subtitle">如果当前账号还没有设置过密码，原密码可以留空，直接设置新的登录密码。</view>
  </view>

  <view class="card form-card">
    <view class="field-item">
      <view class="field-label">原密码</view>
      <input class="field-input" password placeholder="如未设置可留空" value="{{ oldPassword }}" data-field="oldPassword" bindinput="handleInput" />
    </view>
    <view class="field-item">
      <view class="field-label">新密码</view>
      <input class="field-input" password placeholder="请输入至少 6 位新密码" value="{{ newPassword }}" data-field="newPassword" bindinput="handleInput" />
    </view>
    <view class="field-item">
      <view class="field-label">确认新密码</view>
      <input class="field-input" password placeholder="请再次输入新密码" value="{{ confirmPassword }}" data-field="confirmPassword" bindinput="handleInput" />
    </view>
  </view>

  <button class="primary-btn submit-btn" loading="{{ saving }}" bindtap="handleSubmit">保存新密码</button>
</view>