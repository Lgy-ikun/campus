.password-page {
  background: linear-gradient(180deg, #f8eee5 0%, #f7f1eb 220rpx, #f7f1eb 100%);
}

.field-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #edf0ea;
}

.field-item:last-child {
  border-bottom: none;
}

.field-label {
  font-size: 24rpx;
  color: #6b7280;
}

.field-input {
  margin-top: 12rpx;
  padding: 14rpx 0;
  font-size: 28rpx;
  color: #3f2d26;
}

.submit-btn {
  margin-top: 8rpx;
}
